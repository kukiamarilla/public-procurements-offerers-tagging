# Digital Ocean Spaces (S3-compatible)
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_REGION=tor1
DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
DO_SPACES_ACCESS_KEY_ID=
DO_SPACES_SECRET_ACCESS_KEY=

# Bucket prefixes
DO_SPACES_PREFIX_INPUT=tagging/ids
DO_SPACES_PREFIX_PDFS=tagging/pdfs
DO_SPACES_PREFIX_RESULTS=tagging/results

# API (optional)
PORT=3000
API_PREFIX=api
